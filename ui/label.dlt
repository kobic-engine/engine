##############################
# Kobic Engine — Label
# Text label UI component
##############################

@component
struct LabelData:
    text_ptr:   i64 = 0
    anchor:     i32 = 0
    font_size:  i32 = 16
    color_r:    f32 = 1.0
    color_g:    f32 = 1.0
    color_b:    f32 = 1.0
    color_a:    f32 = 1.0

imm ANCHOR_TOP_LEFT:     i32 = 0
imm ANCHOR_TOP_RIGHT:    i32 = 1
imm ANCHOR_BOTTOM_LEFT:  i32 = 2
imm ANCHOR_BOTTOM_RIGHT: i32 = 3
imm ANCHOR_CENTER:       i32 = 4
