##############################
# Kobic Engine — Shapes
# Collision shape data structs
##############################

imm SHAPE_BOX: i32 = 0
imm SHAPE_CAPSULE: i32 = 1
imm SHAPE_SPHERE: i32 = 2

struct BoxShape:
    half_x: f32 = 0.5
    half_y: f32 = 0.5
    half_z: f32 = 0.5

struct CapsuleShape:
    radius: f32 = 0.3
    height: f32 = 1.0

struct SphereShape:
    radius: f32 = 0.5
